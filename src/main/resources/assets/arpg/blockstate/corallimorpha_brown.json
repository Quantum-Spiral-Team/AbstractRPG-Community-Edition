{
	"multipart": [
		{
			"when": { "facing": "up" },
			"apply": { "model": "arpg:corallimorpha" }
		},
		{
			"when": { "facing": "down" },
			"apply": { "model": "arpg:corallimorpha", "x": 180 }
		},
		{
			"when": { "facing": "north" },
			"apply": { "model": "arpg:corallimorpha", "x": 90 }
		},
		{
			"when": { "facing": "south" },
			"apply": { "model": "arpg:corallimorpha", "x": 90, "y": 180 }
		},
		{
			"when": { "facing": "west" },
			"apply": { "model": "arpg:corallimorpha", "x": 90, "y": 270 }
		},
		{
			"when": { "facing": "east" },
			"apply": { "model": "arpg:corallimorpha", "x": 90, "y": 90 }
		}
	]
}